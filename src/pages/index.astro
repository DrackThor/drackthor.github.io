---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import { talks } from "../data/talks";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const last_posts = posts.slice(0, 3);

// Upcoming talks: dated today or later, soonest first.
const today = new Date();
today.setHours(0, 0, 0, 0);
const upcomingTalks = talks
  .filter((t) => new Date(t.date) >= today)
  .sort((a, b) => a.date.localeCompare(b.date));
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Daniel Drack</div>
    <div class="text-3xl py-3 font-bold">
      Consultant | Engineer | Educator | Ambassador
    </div>
    <div class="py-2">
      <text class="text-lg">
        ... aka DrackThor 🚜<br /><br />

        I'm a DevOps guy from Graz, Austria.<br />
        @ <b>FullStackS</b> I'm a senior DevOps Consultant and Cloud Native Security
        Evangelist. So far, I've been working with 30+ customers across Europe on
        Kubernetes platforms, automation, and software supply-chain & runtime security,
        in the past four years alone.<br /><br />
        I'm also an eager community organizer, <b>CNCF Ambassador</b> and <b
          >Kubestronaut</b
        >. So besides my consulting gig I help to organize Cloud Native Days and
        Cloud Native Graz, speak across Europe, and lecture at two Austrian
        universities of applied sciences.
      </text>
    </div>
    <div class="mt-8">
      <a
        class="btn"
        href="https://www.linkedin.com/in/drackthor/"
        target="_blank"
      >
        Let's connect!</a
      >
      <a href="/cv" class="btn btn-outline ml-5"> About / CV </a>
    </div>
  </div>

  {
    upcomingTalks.length > 0 && (
      <div class="mb-8">
        <div class="text-3xl w-full font-bold mb-2">Upcoming talks 🔜</div>
        {upcomingTalks.map((t) => (
          <>
            <div class="py-3">
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1">
                <h2 class="text-lg font-bold">{t.title}</h2>
                <span class="font-mono text-sm opacity-70 shrink-0 md:ml-4">
                  {t.date}
                </span>
              </div>
              <div class="text-sm opacity-80">
                {t.event}
                {t.location ? ` · ${t.location}` : ""}
              </div>
              {t.slides && (
                <div class="mt-1 flex gap-2">
                  <a
                    href={t.slides}
                    target="_blank"
                    class="badge badge-outline"
                  >
                    Slides
                  </a>
                </div>
              )}
            </div>
            <div class="divider my-0" />
          </>
        ))}
      </div>
    )
  }

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured talks 🎤</div>
  </div>

  <HorizontalCard
    title="A Brief History of Cloud-Native"
    img="/images/251007-cnda.png"
    desc="From mainframes and virtualization to containers - tying technological milestones to methodology shifts and economics. Cloud Native Days Austria 2025."
    url="https://youtu.be/4Xw2rm5wlrc"
    badge="VIDEO"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Four years of building k8s platforms"
    img="/images/250710-wad.jpeg"
    desc="Technical and organizational lessons from building Kubernetes platforms across dozens of customers. WeAreDevelopers 2025, Berlin."
    url="https://youtu.be/D3e9VFCrD_8"
    badge="VIDEO"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Cloud-native software supply chain security: the hard truth"
    img="/images/240607-area41.png"
    desc="Real-world adoption rates of SBOM, attestation, MFA and signing - based on master's thesis research. Area41 2024, Zürich."
    url="https://www.youtube.com/watch?v=gkAr51q296o"
    badge="VIDEO"
  />
  <div class="mt-4">
    <a href="/talks" class="btn btn-sm btn-outline">See all talks →</a>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.id)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
